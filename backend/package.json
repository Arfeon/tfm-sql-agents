{
  "name": "graphsql-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "tsx src/cli/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:diagnostic": "vitest run tests/diagnostic",
    "test:integration": "vitest run tests/integration",
    "seed": "tsx ../setup/datasets/arcadia/seedData.ts",
    "prepare": "cd .. && husky backend/.husky"
  },
  "dependencies": {
