# ===========================================
# GraphSQL Configuration
# ===========================================

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ===========================================
# Neo4J Configuration (Knowledge Graph)
# ===========================================
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ===========================================
# PostgreSQL + PgVector (Memory & Embeddings)
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=graphsql_memory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# NOTE: docker-compose reads `NEO4J_USER` and `NEO4J_PASSWORD`
# to form `NEO4J_AUTH` (i.e. user/password). Copy values
# into a local `.env` file for development and do not commit
# secrets to version control.

# ===========================================
# Target Database Configuration
# (The database you want to query with natural language)
# ===========================================
TARGET_DB_TYPE=mssql
# Options: mssql, mysql, postgresql, oracle

TARGET_DB_HOST=localhost
TARGET_DB_PORT=1433
TARGET_DB_NAME=your_database
TARGET_DB_USER=sa
TARGET_DB_PASSWORD=your-db-password

# Optional: Full connection string (overrides above)
# TARGET_DB_CONNECTION_STRING=mssql+pyodbc://user:pass@host/db?driver=ODBC+Driver+17+for+SQL+Server

# ===========================================
# Agent Configuration
# ===========================================
MAX_ITERATIONS=3
REQUIRE_HUMAN_APPROVAL=true
SIMILARITY_THRESHOLD=0.75
MAX_FEEDBACK_EXAMPLES=5

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
DEBUG=false
