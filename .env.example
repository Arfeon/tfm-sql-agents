# ===========================================
# Configuración de GraphSQL
# ===========================================

# Proveedor del modelo de chat
LLM_PROVIDER=openai
# Opciones: openai (nube) | local (LM Studio, API compatible con OpenAI)
# Opcional: déjalo vacío para usar la temperatura por defecto del modelo (algunos rechazan otros valores)
LLM_TEMPERATURE=

# Configuración de OpenAI
OPENAI_API_KEY=sk-tu-api-key-aqui
OPENAI_MODEL=gpt-4o-mini

# LLM local (LM Studio) — expone una API compatible con OpenAI
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_API_KEY=lm-studio

# Embeddings (vectorización del esquema). El proveedor se elige en el CLI al escanear.
# IMPORTANTE: hay que indexar y consultar con el MISMO modelo. Cambiarlo obliga a re-vectorizar.
# Proveedor por defecto para usos no interactivos / tests:
EMBEDDING_PROVIDER=openai
# Configuración por proveedor (modelo + dimensión):
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
# Local (LM Studio): bge-m3=1024, multilingual-e5-large=1024
LMSTUDIO_EMBEDDING_MODEL=text-embedding-bge-m3
LMSTUDIO_EMBEDDING_DIMENSIONS=1024

# ===========================================
# Configuración de Neo4j (grafo de conocimiento)
# ===========================================
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tu-password-de-neo4j
NEO4J_DATABASE=neo4j

# ===========================================
# PostgreSQL + pgvector (memoria y embeddings)
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=graphsql_memory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu-password-de-postgres

# NOTA: docker-compose lee `NEO4J_USER` y `NEO4J_PASSWORD` para formar
# `NEO4J_AUTH` (usuario/contraseña). Copia los valores a un `.env` local
# para desarrollo y no subas secretos al control de versiones.

# ===========================================
# Base de datos objetivo
# (la que quieres consultar en lenguaje natural)
# ===========================================
# Catálogo de BDs objetivo, numeradas: TARGET_DB_1_*, TARGET_DB_2_*, ...
# El CLI las muestra para elegir cuál escanear. TYPE soportado: postgresql.
TARGET_DB_1_TYPE=postgresql
TARGET_DB_1_HOST=localhost
TARGET_DB_1_PORT=5432
TARGET_DB_1_NAME=tu_base_de_datos
TARGET_DB_1_SCHEMA=public
TARGET_DB_1_USER=postgres
TARGET_DB_1_PASSWORD=tu-password-de-bd

# Añade más BDs incrementando el índice:
# TARGET_DB_2_TYPE=postgresql
# TARGET_DB_2_HOST=localhost
# TARGET_DB_2_PORT=5432
# TARGET_DB_2_NAME=otra_bd
# TARGET_DB_2_SCHEMA=public
# TARGET_DB_2_USER=postgres
# TARGET_DB_2_PASSWORD=...

# ===========================================
# Configuración del agente
# ===========================================
MAX_ITERATIONS=3
REQUIRE_HUMAN_APPROVAL=true
SIMILARITY_THRESHOLD=0.75
MAX_FEEDBACK_EXAMPLES=5

# ===========================================
# Logs
# ===========================================
LOG_LEVEL=INFO
DEBUG=false
