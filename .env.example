# ===========================================
# GraphSQL Configuration
# ===========================================

# LLM Provider Selection
LLM_PROVIDER=openai
# Options: openai (cloud) | local (LM Studio, OpenAI-compatible)
# Optional: leave empty to use the model's default (some models reject custom values)
LLM_TEMPERATURE=

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Local LLM (LM Studio) — exposes an OpenAI-compatible API
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_API_KEY=lm-studio

# ===========================================
# Neo4J Configuration (Knowledge Graph)
# ===========================================
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ===========================================
# PostgreSQL + PgVector (Memory & Embeddings)
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=graphsql_memory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# NOTE: docker-compose reads `NEO4J_USER` and `NEO4J_PASSWORD`
# to form `NEO4J_AUTH` (i.e. user/password). Copy values
# into a local `.env` file for development and do not commit
# secrets to version control.

# ===========================================
# Target Database Configuration
# (The database you want to query with natural language)
# ===========================================
# Catálogo de BDs objetivo, numeradas: TARGET_DB_1_*, TARGET_DB_2_*, ...
# El CLI las muestra para elegir cuál escanear. TYPE soportado: postgresql.
TARGET_DB_1_TYPE=postgresql
TARGET_DB_1_HOST=localhost
TARGET_DB_1_PORT=5432
TARGET_DB_1_NAME=your_database
TARGET_DB_1_SCHEMA=public
TARGET_DB_1_USER=postgres
TARGET_DB_1_PASSWORD=your-db-password

# Añade más BDs incrementando el índice:
# TARGET_DB_2_TYPE=postgresql
# TARGET_DB_2_HOST=localhost
# TARGET_DB_2_PORT=5432
# TARGET_DB_2_NAME=otra_bd
# TARGET_DB_2_SCHEMA=public
# TARGET_DB_2_USER=postgres
# TARGET_DB_2_PASSWORD=...

# ===========================================
# Agent Configuration
# ===========================================
MAX_ITERATIONS=3
REQUIRE_HUMAN_APPROVAL=true
SIMILARITY_THRESHOLD=0.75
MAX_FEEDBACK_EXAMPLES=5

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
DEBUG=false
